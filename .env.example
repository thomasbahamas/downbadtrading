# ============================================================
# SOLANA TRADING AGENT — ENVIRONMENT VARIABLES
# ============================================================
# Copy to .env and fill in your values before running.
# NEVER commit .env to version control.

# ─── Solana Wallet ───────────────────────────────────────────
# Trading wallet: base58-encoded private key (bs58 format)
# Keep minimal balance — just enough for trades + gas
SOLANA_PRIVATE_KEY=<base58_private_key>

# Separate cold wallet where profits are routed after each win
PROFIT_WALLET_ADDRESS=<solana_pubkey>

# ─── Helius ─────────────────────────────────────────────────
# Get from https://helius.dev
HELIUS_API_KEY=<helius_api_key>
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=<helius_api_key>
HELIUS_WS_URL=wss://mainnet.helius-rpc.com/?api-key=<helius_api_key>

# ─── Jupiter ─────────────────────────────────────────────────
# Trigger V2 API key — request access at https://dev.jup.ag/
JUPITER_API_KEY=<jupiter_api_key>
JUPITER_ULTRA_BASE_URL=https://api.jup.ag/ultra/v1
JUPITER_TRIGGER_BASE_URL=https://api.jup.ag/trigger/v2

# ─── LLM Provider ────────────────────────────────────────────
# Primary: Anthropic Claude
ANTHROPIC_API_KEY=<anthropic_api_key>
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_SCREENING_MODEL=claude-haiku-4-5-20251001

# Fallback: OpenAI GPT-4o
OPENAI_API_KEY=<openai_api_key>
OPENAI_MODEL=gpt-4o

# Which provider to use: 'anthropic' | 'openai'
LLM_PROVIDER=anthropic

# ─── Market Data ─────────────────────────────────────────────
# Birdeye Pro API key — https://birdeye.so/developers
BIRDEYE_API_KEY=<birdeye_api_key>
BIRDEYE_BASE_URL=https://public-api.birdeye.so

# CoinGecko API key — https://www.coingecko.com/en/api
# Demo key uses api.coingecko.com; Pro key uses pro-api.coingecko.com
COINGECKO_API_KEY=<coingecko_api_key>
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3

# ─── Telegram Notifications ──────────────────────────────────
# Create a bot via @BotFather, then get chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=<bot_token>
TELEGRAM_CHAT_ID=<your_chat_id>

# ─── Database ────────────────────────────────────────────────
# Create a project at https://supabase.com, run schema.sql
SUPABASE_URL=https://<project_ref>.supabase.co
SUPABASE_SERVICE_KEY=<service_role_key>   # agent (full access)
SUPABASE_ANON_KEY=<anon_key>              # dashboard (RLS-gated)

# ─── Agent Behavior ──────────────────────────────────────────
# Max USD value for fully-autonomous trades (above this → Telegram approval)
MAX_AUTO_TRADE_USD=500

# Loop interval in seconds (how often the agent wakes up to check markets)
LOOP_INTERVAL_SECONDS=180

# Risk parameters (override defaults in risk/engine.ts)
MAX_PORTFOLIO_EXPOSURE_PCT=30
MAX_SINGLE_TOKEN_PCT=10
MAX_CONCURRENT_POSITIONS=5
MIN_CONFIDENCE_SCORE=0.7
MIN_LIQUIDITY_USD=50000
MIN_TOKEN_AGE_HOURS=24
DEFAULT_TP_PCT=15
DEFAULT_SL_PCT=8
MAX_DAILY_LOSS_PCT=5
MAX_CONSECUTIVE_LOSSES=3
MAX_DRAWDOWN_PCT=15
ORDER_EXPIRY_DAYS=7

# Comma-separated Solana mint addresses to never trade (Drift is always blacklisted)
BLACKLISTED_MINTS=

# ─── Environment ─────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
PAPER_TRADE=false
